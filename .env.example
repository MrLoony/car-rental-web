APP_NAME="Car Rental Web"
APP_ENV=development
# Render sets PORT automatically. APP_PORT remains useful for local development.
PORT=
APP_PORT=8080
BASE_URL=http://localhost:8080
DATABASE_URL=postgres://car_rental_user:car_rental_password@localhost:5432/car_rental_web?sslmode=disable
SESSION_SECRET=change-me-in-development
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-production

EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp

# SMTP settings. Use EMAIL_PROVIDER=smtp for local SMTP testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME="Car Rental Web"

# Brevo HTTP API settings. Use EMAIL_PROVIDER=brevo on Render if SMTP ports time out.
# Do not commit real API keys.
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME="Car Rental Web"

ADMIN_NOTIFICATION_EMAIL=
